# ════════════════════════════════════════════════════════════
# backend_vultr/.env
# Copy this file → rename to .env → fill in your values
# NEVER commit .env to GitHub
# ════════════════════════════════════════════════════════════

# ── GEMINI ───────────────────────────────────────────────────
GEMINI_API_KEY=                          # GET: aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash-lite       # keep this exact value

# ── IBM QUANTUM ──────────────────────────────────────────────
IBM_QUANTUM_TOKEN=                       # GET: quantum.ibm.com → Account → API token
                                         # Leave empty → uses free local Aer simulator
IBM_MAX_QUBITS=20                        # keep this value
SHOTS_FINAL=4096                         # keep this value

# ── SPEECHMATICS (sponsor — $200 free credit) ────────────────
SPEECHMATICS_API_KEY=                    # GET: portal.speechmatics.com → API Keys
SPEECHMATICS_LANGUAGE=en                 # keep this value

# ── TOMTOM TRAFFIC ───────────────────────────────────────────
TOMTOM_API_KEY=                          # GET: developer.tomtom.com → My Apps → New App → copy Primary Key

# ── CLIMATIQ CARBON ──────────────────────────────────────────
CLIMATIQ_API_KEY=                        # GET: climatiq.io/signup → Dashboard → API key
                                         # Leave empty → uses offline fallback (still works)

# ── TELEGRAM DISPATCH ALERTS ─────────────────────────────────
TELEGRAM_BOT_TOKEN=                      # GET: Telegram → @BotFather → /newbot → copy token
TELEGRAM_CHAT_ID=                        # GET: curl "https://api.telegram.org/bot<TOKEN>/getUpdates" → find "id"

# ── SUPABASE JOB HISTORY ─────────────────────────────────────
SUPABASE_URL=                            # GET: supabase.com → your project → Settings → API → Project URL
SUPABASE_ANON_KEY=                       # GET: supabase.com → your project → Settings → API → anon/public key

# ── AMD WHISPER NODE URL ─────────────────────────────────────
AMD_WHISPER_URL=                         # SET AFTER AMD STEP: https://abc-random.trycloudflare.com
                                         # Leave empty in local dev → uses default instruction fallback

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app
# ADD your exact Vercel URL after deploy, e.g:
# ALLOWED_ORIGINS=http://localhost:3000,https://q-optima.vercel.app

# ── UPLOAD LIMITS ────────────────────────────────────────────
MAX_UPLOAD_MB=25                         # keep this value
